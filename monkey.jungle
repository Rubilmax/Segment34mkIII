project.manifest = manifest.xml
project.typecheck = 1
project.optimization = 3p

# =============================================================================
# EXPLICIT DEVICE ENTRIES
# Each device has its own complete excludeAnnotations list.
# Low-memory devices (96KB) exclude WeatherCache.
# All other devices exclude NoWeatherCache.
# =============================================================================

# -----------------------------------------------------------------------------
# 240x240 MIP DEVICES
# -----------------------------------------------------------------------------

# Low memory (96KB) - no weather caching
fenix6s.excludeAnnotations = Round260;Round280;Round360;Round390;Round416;Round454;AMOLED;InstinctCrossover;WeatherCache;Square
fenix6s.resourcePath = resources;disp-resources/mip;size-resources/s240

